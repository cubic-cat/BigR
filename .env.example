# Provider registry
# These entries are selected automatically according to EMBEDDING_PROVIDER / LLM_PROVIDER.
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Optional module-level overrides
# Leave blank unless you need embedding and llm to use different credentials
# under the same provider, or want a custom proxy / gateway.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
LLM_BASE_URL=
LLM_API_KEY=

# Embedding
# If you change EMBEDDING_PROVIDER, also check EMBEDDING_MODEL_NAME.
EMBEDDING_PROVIDER=qwen
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_NORMALIZE=true
EMBEDDING_REQUEST_TIMEOUT=30

# LLM
# If you change LLM_PROVIDER, also check LLM_MODEL_NAME.
LLM_PROVIDER=qwen
LLM_MODEL_NAME=qwen3.5-flash
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
LLM_MAX_TOKENS=1024
LLM_STREAMING=false
LLM_REQUEST_TIMEOUT=60

# Vector Store
VECTOR_DB_PROVIDER=local
VECTOR_DB_COLLECTION_NAME=rag_knowledge_base
VECTOR_DB_DISTANCE_METRIC=cosine
VECTOR_DB_PERSIST_DIRECTORY=vector_store
